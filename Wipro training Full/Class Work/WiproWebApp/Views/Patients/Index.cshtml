@model IEnumerable<WiproWebApp.Models.Patient><link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" /><table class="table">    <tr>        <th>Id</th>        <th>Name</th>    </tr>    @foreach (var item in Model)    {        <tr>            <td>@Html.DisplayFor(e => item.Id)</td>            <td>@Html.DisplayFor(e => item.Name)</td>            <td></td>        </tr>    }</table>