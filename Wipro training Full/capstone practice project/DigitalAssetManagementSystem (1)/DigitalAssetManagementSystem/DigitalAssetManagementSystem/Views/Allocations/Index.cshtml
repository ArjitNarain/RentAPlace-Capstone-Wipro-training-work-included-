@model IEnumerable<DigitalAssetManagementSystem.entity.AssetAllocation>
@{
    ViewData["Title"] = "Allocations";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Asset Allocations</h2>
        <div>
            <a class="btn btn-primary" asp-action="Allocate">Allocate</a>
            <a class="btn btn-secondary" asp-action="Deallocate">Deallocate</a>
        </div>
    </div>

    @if (TempData["Msg"] != null)
    {
        <div class="alert alert-success mt-2">@TempData["Msg"]</div>
    }
    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger mt-2">@TempData["Err"]</div>
    }

    <table class="table table-striped mt-3">
        <thead>
            <tr><th>ID</th><th>Asset</th><th>Employee</th><th>Allocated</th><th>Returned</th></tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.AllocationId</td>
                    <td>@a.Asset?.Name (@a.AssetId)</td>
                    <td>@a.Employee?.Name (@a.EmployeeId)</td>
                    <td>@a.AllocationDate.ToShortDateString()</td>
                    <td>@(a.ReturnDate?.ToShortDateString() ?? "Active")</td>
                </tr>
            }
        </tbody>
    </table>
</div>