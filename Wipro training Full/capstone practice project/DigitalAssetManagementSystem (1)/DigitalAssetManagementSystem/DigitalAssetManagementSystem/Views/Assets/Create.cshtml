@model DigitalAssetManagementSystem.entity.Asset
@{
    ViewData["Title"] = "Add Asset";
}

<div class="container py-4">
    <h2>Add Asset</h2>

    <form asp-action="Create" method="post" class="mt-3">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Type</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Serial Number</label>
                <input asp-for="SerialNumber" class="form-control" />
                <span asp-validation-for="SerialNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Purchase Date</label>
                <input asp-for="PurchaseDate" type="date" class="form-control" />
                <span asp-validation-for="PurchaseDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Location</label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option>in use</option>
                    <option>decommissioned</option>
                    <option>under maintenance</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Owner</label>
                <select asp-for="OwnerId" class="form-select" asp-items="ViewBag.OwnerId">
                    <option value="">-- None --</option>
                </select>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-success" type="submit">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}