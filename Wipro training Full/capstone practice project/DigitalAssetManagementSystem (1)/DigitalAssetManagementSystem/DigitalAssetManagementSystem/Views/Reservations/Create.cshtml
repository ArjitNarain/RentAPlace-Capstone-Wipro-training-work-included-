@{
    ViewData["Title"] = "Reserve Asset";
}

<div class="container py-4">
    <h2>Reserve Asset</h2>

    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger mt-2">@TempData["Err"]</div>
    }

    <form asp-action="Create" method="post" class="mt-3">
        <div class="mb-2">
            <label class="form-label">Asset</label>
            <select name="assetId" class="form-select" asp-items="ViewBag.Assets"></select>
        </div>

        <div class="mb-2">
            <label class="form-label">Employee</label>
            <select name="employeeId" class="form-select" asp-items="ViewBag.Employees"></select>
        </div>

        <div class="mb-2">
            <label class="form-label">Reservation Date</label>
            <input name="reservationDate" type="date" class="form-control" required />
        </div>

        <div class="mb-2">
            <label class="form-label">Start Date</label>
            <input name="startDate" type="date" class="form-control" required />
        </div>

        <div class="mb-2">
            <label class="form-label">End Date</label>
            <input name="endDate" type="date" class="form-control" required />
        </div>

        <button class="btn btn-success" type="submit">Reserve</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </form>
</div>